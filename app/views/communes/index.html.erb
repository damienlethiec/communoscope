<% content_for :title, "Communoscope — feux finances des communes" %>

<div class="w-full space-y-8">
  <header class="space-y-1">
    <h1 class="text-2xl font-bold">Communoscope</h1>
    <p class="text-sm text-gray-600">
      Feux finances des communes de la Métropole de Lyon, indicateurs officiels sourcés.
    </p>
  </header>

  <ul role="list" class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
    <% @communes.each do |commune| %>
      <% feu = @feux_finances[commune.id] %>
      <li data-commune="<%= commune.id %>"
          class="rounded-lg border border-gray-200 bg-white p-4 shadow-sm space-y-3">
        <div class="flex items-start justify-between gap-2">
          <div>
            <h2 data-nom class="font-semibold"><%= commune.nom %></h2>
            <% if commune.population %>
              <p class="text-sm text-gray-500">
                <%= number_with_delimiter(commune.population, delimiter: " ") %> habitants
              </p>
            <% end %>
          </div>
          <%= badge_feu_carte(feu) %>
        </div>

        <% if feu %>
          <div class="space-y-2 text-sm">
            <p class="text-gray-600">Exercice <%= feu.justification["annee"] %></p>
            <ul class="flex flex-wrap gap-x-3 gap-y-1">
              <% feu.justification["indicateurs"].each do |indicateur| %>
                <li class="flex items-center gap-1.5">
                  <span aria-hidden="true"><%= FeuxHelper::ICONES.fetch(indicateur["couleur"]) %></span>
                  <span class="text-gray-700"><%= indicateur["libelle"] %></span>
                  <span class="sr-only">: <%= indicateur["couleur"] %></span>
                </li>
              <% end %>
            </ul>
          </div>
        <% else %>
          <p class="text-sm text-gray-500">Feu finances non encore calculé.</p>
        <% end %>
      </li>
    <% end %>
  </ul>
</div>
